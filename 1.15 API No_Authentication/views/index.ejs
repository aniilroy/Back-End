<!DOCTYPE html>
<html>

<head>

    <title>Joke Generator</title>

    <style>

        body{
            font-family: Arial, sans-serif;
            background:#f4f4f4;
            padding:40px;
        }

        .card{
            max-width:600px;
            margin:auto;
            background:white;
            padding:25px;
            border-radius:10px;
        }

        h1{
            color:#2563eb;
        }

    </style>

</head>

<body>

    <div class="card">

        <h1>Random Joke 😂</h1>

        <h3><%= joke.setup %></h3>

        <p><%= joke.punchline %></p>

    </div>

</body>

</html>